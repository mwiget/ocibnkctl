# tmm telemetry — mutating admission webhook + serving cert.
#
# The f5-tmm pod is created by the F5Tmm operator, so its spec can't be patched
# directly. This webhook injects the tmm-stat-exporter sidecar (which reads tmm's
# /var/tmstat segment and pushes Prometheus remote_write to bnk-forge) into pods
# labelled app=f5-tmm at admission — surviving operator reconciliation.
#
# The serving cert is issued by cert-manager (installed by `deploy prereqs`); the
# webhook's caBundle is filled by cert-manager's cainjector via the
# cert-manager.io/inject-ca-from annotation, so no caBundle is hand-managed.
apiVersion: cert-manager.io/v1
kind: Issuer
metadata:
  name: tmm-stat-webhook
  namespace: {{ .Namespace }}
spec:
  selfSigned: {}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: tmm-stat-webhook
  namespace: {{ .Namespace }}
spec:
  secretName: tmm-stat-webhook-tls
  duration: 87600h   # 10y — long-lived; this is infra plumbing, not a workload identity
  dnsNames:
    - tmm-stat-webhook.{{ .Namespace }}.svc
    - tmm-stat-webhook.{{ .Namespace }}.svc.cluster.local
  issuerRef:
    name: tmm-stat-webhook
    kind: Issuer
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: tmm-stat-webhook
  namespace: {{ .Namespace }}
  labels:
    app: tmm-stat-webhook
spec:
  replicas: 1
  selector:
    matchLabels:
      app: tmm-stat-webhook
  template:
    metadata:
      labels:
        app: tmm-stat-webhook
    spec:
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
      containers:
        - name: webhook
          image: {{ .WebhookImage }}
          imagePullPolicy: IfNotPresent
          args:
            - --remote-write-url={{ .RemoteWriteURL }}
            - --cluster={{ .ClusterName }}
            - --exporter-image={{ .ExporterImage }}
          ports:
            - containerPort: 8443
          readinessProbe:
            tcpSocket:
              port: 8443
            initialDelaySeconds: 2
            periodSeconds: 5
          securityContext:
            runAsNonRoot: true
            readOnlyRootFilesystem: true
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
          resources:
            requests: {cpu: 25m, memory: 32Mi}
            limits: {cpu: 50m, memory: 64Mi}
          volumeMounts:
            - name: tls
              mountPath: /tls
              readOnly: true
      volumes:
        - name: tls
          secret:
            secretName: tmm-stat-webhook-tls
---
apiVersion: v1
kind: Service
metadata:
  name: tmm-stat-webhook
  namespace: {{ .Namespace }}
spec:
  selector:
    app: tmm-stat-webhook
  ports:
    - port: 443
      targetPort: 8443
---
apiVersion: admissionregistration.k8s.io/v1
kind: MutatingWebhookConfiguration
metadata:
  name: tmm-stat-webhook
  annotations:
    cert-manager.io/inject-ca-from: {{ .Namespace }}/tmm-stat-webhook
webhooks:
  - name: tmm-stat.f5.local
    clientConfig:
      service:
        name: tmm-stat-webhook
        namespace: {{ .Namespace }}
        path: /mutate
        port: 443
    rules:
      - operations: ["CREATE"]
        apiGroups: [""]
        apiVersions: ["v1"]
        resources: ["pods"]
        scope: Namespaced
    objectSelector:
      matchLabels:
        app: f5-tmm
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: {{ .Namespace }}
    # Never block tmm pod creation if the webhook is down — telemetry is
    # best-effort and must not wedge the dataplane.
    failurePolicy: Ignore
    sideEffects: None
    admissionReviewVersions: ["v1"]
