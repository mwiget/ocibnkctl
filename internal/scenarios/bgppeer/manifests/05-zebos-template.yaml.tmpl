# Patches the cluster-wide f5-tmm-dynamic-routing-template ConfigMap
# with a ZeBOS BGP config that peers with FRR over the Multus NAD
# interface. Multus assigns this interface as net1 (default naming);
# ZeBOS sources BGP from net1 so packets bypass TMM's eth0 hook
# entirely.
#
# FRR's NAD IP is the fixed 192.168.99.11 from the FRR Deployment's
# annotation. TMM's NAD IP is dynamic (assigned by host-local IPAM
# inside the .20-.250 range) and isn't needed in the ZeBOS config
# because FRR uses `bgp listen range` to accept any incoming peer.
apiVersion: v1
kind: ConfigMap
metadata:
  name: f5-tmm-dynamic-routing-template
  namespace: default
data:
  ZebOS.conf: |
    router bgp 65000
      bgp router-id %%POD_IP%%
      bgp log-neighbor-changes
      bgp graceful-restart restart-time 120
      no bgp default ipv4-unicast
      ! Redistribute both kernel routes (Gateway /32s installed
      ! by FLO; route type "K" in ZeBOS RIB) and connected routes
      ! (net1's 192.168.99.0/24; route type "C"). ZeBOS treats
      ! C and K as distinct origins — `redistribute kernel` alone
      ! does NOT pick up directly-connected interface subnets, so
      ! both lines are needed for FRR to learn the NAD subnet
      ! plus any per-scenario Gateway IP.
      ! Both must appear at router-bgp scope, not inside
      ! address-family — F5 ZeBOS silently drops them from
      ! `address-family ipv4` with no visible error.
      redistribute kernel
      redistribute connected
      !
      neighbor {{.FRRNetIP}} remote-as 65001
      neighbor {{.FRRNetIP}} update-source net1
      !
      address-family ipv4
        neighbor {{.FRRNetIP}} activate
        neighbor {{.FRRNetIP}} soft-reconfiguration inbound
      exit-address-family
    !
